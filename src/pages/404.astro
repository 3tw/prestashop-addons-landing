---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Page not found — Better Addon"
  description="The page you're looking for doesn't exist. Head back to the Better Addon home page."
>
  <Header />
  <main class="bg-primary-dark min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-xl">
      <p class="text-sm font-semibold tracking-widest uppercase text-primary">404</p>
      <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight text-white leading-tight">
        That page wandered off.
      </h1>
      <p class="mt-6 text-lg text-on-dark max-w-md mx-auto leading-relaxed">
        The link is broken or the page has moved. From here you can head home or jump straight to the module.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-block rounded-lg bg-primary px-8 py-4 text-lg font-semibold text-primary-dark shadow-2xl hover:bg-primary-light hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0 transition-all duration-300"
        >
          Back to home
        </a>
        <a
          href="/#features"
          class="inline-block rounded-lg border-[1.5px] border-white/20 px-8 py-4 text-lg font-semibold text-white hover:border-white/40 hover:bg-white/5 transition-all duration-300"
        >
          See features
        </a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
