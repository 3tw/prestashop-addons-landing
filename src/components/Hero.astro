---
interface Props {
  headline: string;
  subheadline: string;
  ctaText: string;
  ctaUrl: string;
  socialProof?: {
    installs: string;
    rating: string;
    compatibility: string;
  };
}

const { headline, subheadline, ctaText, ctaUrl, socialProof } = Astro.props;
---

<section class="relative overflow-hidden bg-primary-dark" style="background: radial-gradient(ellipse at 50% 0%, #3C3489 0%, #26215C 70%);">
  <!-- Decorative gradient blobs -->
  <div class="pointer-events-none absolute -top-24 -left-24 h-96 w-96 rounded-full bg-on-dark-subtle/20 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-32 -right-32 h-[28rem] w-[28rem] rounded-full bg-primary/15 blur-3xl"></div>

  <div class="relative mx-auto max-w-6xl px-6 py-28 md:py-40 text-center">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-white leading-tight max-w-4xl mx-auto">
      {headline}
    </h1>
    <p class="mt-6 text-lg md:text-xl text-on-dark max-w-3xl mx-auto leading-relaxed">
      {subheadline}
    </p>
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={ctaUrl}
        target="_blank"
        rel="noopener"
        class="inline-block rounded-lg bg-white px-8 py-4 text-lg font-semibold text-primary-dark shadow-2xl hover:bg-primary-light hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0 transition-all duration-300"
      >
        {ctaText}
      </a>
      <a
        href="/#features"
        class="inline-block rounded-lg border-[1.5px] border-white/20 px-8 py-4 text-lg font-semibold text-white hover:border-white/40 hover:bg-white/5 transition-all duration-300"
      >
        See features
      </a>
    </div>
    <p class="mt-6 text-sm text-on-dark-muted">Works with PrestaShop 8.x &bull; One-time purchase &bull; 30-day guarantee</p>

    {socialProof && (
      <div class="mt-16 border-t border-white/10 pt-8">
        <div class="flex flex-wrap justify-center gap-8 md:gap-16 text-center">
          <div>
            <span class="text-2xl font-bold text-white">{socialProof.installs}</span>
            <p class="text-sm text-on-dark-muted">Installs</p>
          </div>
          <div>
            <span class="text-2xl font-bold text-white">{socialProof.rating}</span>
            <p class="text-sm text-on-dark-muted">Average rating</p>
          </div>
          <div>
            <span class="text-2xl font-bold text-white">{socialProof.compatibility}</span>
            <p class="text-sm text-on-dark-muted">Compatible</p>
          </div>
        </div>
      </div>
    )}
  </div>
</section>
