---
import bgImage from '../assets/images/better-top-banner/background.jpg';
import itemsImage from '../assets/images/better-top-banner/multiple-straight.png';

interface Props {
  headline: string;
  subheadline: string;
  ctaText: string;
  ctaUrl: string;
  socialProof?: {
    compatibility: string;
    price: string;
    license: string;
  };
}

const { headline, subheadline, ctaText, ctaUrl, socialProof } = Astro.props;
---

<section class="relative overflow-hidden bg-primary-dark">
  <!-- Background image -->
  <div
    class="pointer-events-none absolute inset-0 bg-cover bg-center"
    style={`background-image: url('${bgImage.src}');`}
  >
  </div>
  <!-- Dark overlay for text readability -->
  <div class="pointer-events-none absolute inset-0 bg-primary-dark/70"></div>

  <div class="relative mx-auto max-w-6xl px-6 pt-24 pb-16 md:pt-32 md:pb-16">
    <div class="lg:grid lg:grid-cols-12 lg:gap-12 lg:items-center">
      <!-- Left column: text -->
      <div class="text-center lg:text-left lg:col-span-7">
        <p class="text-sm font-semibold tracking-widest uppercase text-primary">
          PrestaShop 8 Module
        </p>
        <h1
          class="mt-4 text-xl md:text-2xl lg:text-5xl font-bold tracking-tight text-white leading-tight"
        >
          {headline}
        </h1>
        <p
          class="mt-6 text-lg md:text-xl text-on-dark max-w-2xl mx-auto lg:mx-0 leading-relaxed"
        >
          {subheadline}
        </p>
        <div
          class="mt-10 flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4"
        >
          <a
            href={ctaUrl}
            target="_blank"
            rel="noopener"
            class="inline-block rounded-lg bg-primary px-8 py-4 text-lg font-semibold text-primary-dark shadow-2xl hover:bg-primary-light hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0 transition-all duration-300"
          >
            {ctaText}
          </a>
          <a
            href="/#features"
            class="inline-block rounded-lg border-[1.5px] border-white/20 px-8 py-4 text-lg font-semibold text-white hover:border-white/40 hover:bg-white/5 transition-all duration-300"
          >
            See features
          </a>
        </div>
        <p class="mt-6 text-sm text-on-dark-muted">
          No subscription &bull; No core overrides &bull; Full unobfuscated PHP
          source
        </p>
      </div>

      <!-- Right column: product image -->
      <div class="mt-12 lg:mt-0 lg:col-span-5">
        <img
          src={itemsImage.src}
          width={itemsImage.width}
          height={itemsImage.height}
          alt="PrestaShop top banner module — countdown, free shipping progress, and welcome banners stacked"
          fetchpriority="high"
          decoding="async"
          class="object-contain w-full max-w-sm lg:max-w-none mx-auto"
        />
      </div>
    </div>

    {
      socialProof && (
        <div class="mt-16 border-t border-white/10 pt-8">
          <div class="flex flex-wrap justify-center gap-8 md:gap-16 text-center">
            <div>
              <span class="text-2xl font-bold text-white">
                {socialProof.compatibility}
              </span>
              <p class="text-sm text-on-dark-muted">Compatibility</p>
            </div>
            <div>
              <span class="text-2xl font-bold text-white">
                {socialProof.price}
              </span>
              <p class="text-sm text-on-dark-muted">Price</p>
            </div>
          </div>
        </div>
      )
    }
  </div>
</section>
