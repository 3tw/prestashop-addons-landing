---
import backofficePreview from '../assets/images/better-top-banner/backoffice-preview.png';
import animation from '../assets/images/better-top-banner/animation.gif';
import freeShipping from '../assets/images/better-top-banner/free-shipping.gif';

interface Screenshot {
  alt: string;
}

interface Props {
  screenshots: Screenshot[];
}

const { screenshots } = Astro.props;

const images = [animation, freeShipping, backofficePreview];
---

<section class="bg-white py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-center text-primary-dark">
      See it in action
    </h2>
    <p class="mt-5 text-center text-muted max-w-xl mx-auto">
      Back-office WYSIWYG preview, storefront countdown, live free-shipping progress.
    </p>
    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {screenshots.map((screenshot, i) => (
        <div class="flex flex-col gap-2">
          <figure class="flex items-center rounded-2xl overflow-hidden ring-1 ring-primary-muted shadow-sm bg-transparent transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
            <img
              src={images[i].src}
              alt={screenshot.alt}
              width={images[i].width}
              height={images[i].height}
              loading="lazy"
              class="w-full h-auto block object-contain"
              />
          </figure>
          <span class="text-center text-shadow-muted text-xs">{screenshot.alt}</span>
        </div>
      ))}
    </div>
  </div>
</section>
