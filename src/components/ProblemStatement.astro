---
interface Problem {
  title: string;
  description: string;
}

interface Props {
  problems: Problem[];
}

const { problems } = Astro.props;
---

<section class="relative overflow-hidden bg-[#1a1a1a] py-16 md:py-24">
  <div class="relative mx-auto max-w-3xl px-6">
    <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-center  text-red-500">
      Sound familiar?
    </h2>
    <p class="mt-5 text-center text-white max-w-xl mx-auto">
      If you've tried to run a real promotion in PrestaShop, you know the drill.
    </p>

    <ul class="mt-12 space-y-6">
      {problems.map((problem) => (
        <li class="flex items-start gap-4">
          <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-red-500/15 mt-0.5">
            <svg class="w-4 h-4" fill="none" stroke="rgb(239 68 68)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <path d="M6 18L18 6M6 6l12 12" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold" style="color: rgb(239 68 68);">{problem.title}</h3>
            <p class="mt-1 text-base text-white leading-relaxed">{problem.description}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
