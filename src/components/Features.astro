---
import FeatureCard from './FeatureCard.astro';

interface Feature {
  icon: string;
  title: string;
  benefit: string;
}

interface Props {
  features: Feature[];
}

const { features } = Astro.props;
---

<section id="features" class="bg-primary-light py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-center text-primary-dark">
      Built for PrestaShop merchants who want it to just work
    </h2>
    <p class="mt-5 text-center text-muted max-w-xl mx-auto">
      Better Top Banner adds the things you actually need to run a real promotion.
    </p>
    <div class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => (
        <FeatureCard icon={feature.icon} title={feature.title} benefit={feature.benefit} />
      ))}
    </div>
  </div>
</section>
