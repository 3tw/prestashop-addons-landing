---
import bgImage from '../assets/images/better-top-banner/background.jpg';

interface Props {
  heading: string;
  intro: string;
  examples: string[];
  closer: string;
}

const { heading, intro, examples, closer } = Astro.props;
---

<section class="relative overflow-hidden bg-primary-dark py-16 md:py-24">
  <!-- Background image -->
  <div
    class="pointer-events-none absolute inset-0 bg-cover bg-center"
    style={`background-image: url('${bgImage.src}');`}
  ></div>
  <!-- Dark overlay for text readability -->
  <div class="pointer-events-none absolute inset-0 bg-primary-dark/70"></div>

  <div class="relative mx-auto max-w-3xl px-6">
    <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-center text-white">
      {heading}
    </h2>
    <p class="mt-5 text-center text-on-dark-muted max-w-xl mx-auto">
      {intro}
    </p>
    <ul class="mt-10 space-y-3 max-w-2xl mx-auto">
      {examples.map((ex) => (
        <li class="flex items-start gap-3 rounded-xl bg-white/5 border border-white/10 px-5 py-4 text-on-dark backdrop-blur-sm transition-all duration-300 hover:bg-white hover:text-primary-dark hover:border-transparent hover:-translate-y-0.5">
          <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-base leading-relaxed">{ex}</span>
        </li>
      ))}
    </ul>
    <p class="mt-10 text-center text-base font-semibold text-primary">{closer}</p>
  </div>
</section>
