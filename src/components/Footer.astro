---
const year = new Date().getFullYear();
---

<footer class="bg-primary-dark text-on-dark-subtle">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8">
      <div>
        <span class="text-lg font-bold text-white">Better Addon</span>
        <p class="mt-2 text-sm">Premium modules for PrestaShop merchants.</p>
      </div>
      <div class="flex gap-8">
        <div>
          <h4 class="text-sm font-semibold text-on-dark mb-3">Product</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/#features" class="text-on-dark-subtle hover:text-on-dark transition-colors duration-300">Features</a></li>
            <li><a href="/#pricing" class="text-on-dark-subtle hover:text-on-dark transition-colors duration-300">Pricing</a></li>
            <li><a href="/#faq" class="text-on-dark-subtle hover:text-on-dark transition-colors duration-300">FAQ</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-sm font-semibold text-on-dark mb-3">Links</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="https://winkler58.gumroad.com/l/better-top-banner" target="_blank" rel="noopener" class="text-on-dark-subtle hover:primary transition-colors duration-300">Gumroad</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="mt-10 pt-6 border-t border-on-dark-subtle/20 text-sm text-center">
      &copy; {year} Better Addon. All rights reserved.
    </div>
  </div>
</footer>
 